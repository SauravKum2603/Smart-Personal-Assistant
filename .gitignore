# Ignore local environment variable keys containing API keys
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Ignore operating system files
.DS_Store
Thumbs.db
desktop.ini

# Ignore local dependencies and runtime logs
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.log

# Ignore local n8n data if running via Docker or a local server setup
.n8n/
